# .env.example
OPENWEATHER_API_KEY=your_openweather_api_key_here
VITE_SUPABASE_URL=        ← paste your Supabase project URL here
VITE_SUPABASE_ANON_KEY=   ← paste your anon key here
VITE_SQUARE_APPLICATION_ID=your_square_application_id_here
VITE_SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ACCESS_TOKEN=<sandbox access token from Square Dashboard>
SQUARE_ENVIRONMENT=sandbox